# .env.example
#
# Committed to the repo. Documents which keys the app needs. NO REAL VALUES.
# Copy this to .env, fill in real values locally, and never commit .env.
#
# Rule: VITE_ prefix = shipped to the browser. Never put a secret behind VITE_.

# ---- Frontend config (client-safe, shipped to browser) --------------------
# Not a secret. Just where the frontend finds the backend.
VITE_API_URL=http://localhost:3001

# ---- Backend / server (port, non-secret) -----------------------------------
PORT=3001

# ---- Login ------------------------------------------------------------------
# Unset = no login (local development). A PUBLIC deployment must set this;
# 12+ characters. Changing it signs everyone out.
APP_PASSWORD=                # SECRET: the dashboard password

# ---- Supabase / Postgres (PropIQ project) ----------------------------------
# The backend talks to Postgres directly via DATABASE_URL (node-postgres,
# Transaction pooler, port 6543) — that's the only one Phase 0 requires.
# The other two are declared for later phases that may add supabase-js.
DATABASE_URL=                # SECRET: Transaction pooler connection string, port 6543
SUPABASE_URL=
SUPABASE_ANON_KEY=            # client-safe (publishable)
SUPABASE_SERVICE_ROLE_KEY=   # SECRET: full access, bypasses RLS, backend only

# ---- Meta / Instagram Graph API (PropIQ Sync app) ---------------------------
# Powers the Marketing page's Instagram sync. Both optional: the app runs
# without them; syncing refuses with a clear message until they are set.
META_ACCESS_TOKEN=           # SECRET: Instagram access token (IG... via Instagram business login)
IG_USER_ID=                  # numeric Instagram Business account id (not the @handle)

# ---- Facebook Page sync (same Meta app) -------------------------------------
# FB_ACCESS_TOKEN starts short-lived; with the app id+secret set the server
# exchanges it for a ~60-day token on first sync and persists it here.
FB_ACCESS_TOKEN=             # SECRET: Facebook-login user token (EAA...)
META_APP_ID=                 # numeric app id (App settings -> Basic)
META_APP_SECRET=             # SECRET: app secret (App settings -> Basic)
FB_PAGE_ID=                  # optional: numeric Page id, only if the account manages several Pages

# ---- Portal sync (sync-integration workstream) ------------------------------
# Property-portal analytics via browser automation of Blue Falcon's OWN agent
# CRMs. Portal LOGIN passwords are the HIGHEST-sensitivity secrets here — a
# leak grants full account access, not just read. Server-side only, never
# VITE_. A portal with no creds is disabled (reported "skipped"), so leave
# unused portals blank. Prefer a read-only CRM sub-account where offered.
BUYRENTKENYA_EMAIL=          # BuyRentKenya agent CRM login email
BUYRENTKENYA_PASSWORD=       # SECRET: BuyRentKenya CRM password
BUYRENTKENYA_AGENCY_ID=      # optional: only if the CRM disambiguates by agency
PROPERTY24_EMAIL=            # Property24 agent portal login email
PROPERTY24_PASSWORD=         # SECRET: Property24 portal password
KEDWELL_EMAIL=               # Kedwell login email (unused until the subscription decision)
KEDWELL_PASSWORD=            # SECRET: Kedwell password

# Scheduling / browser behavior. Cron is OFF unless PORTAL_SYNC_ENABLED=true;
# keep it off until migration 005 is applied live. Defaults shown as comments.
PORTAL_SYNC_ENABLED=         # "true" arms the daily cron; anything else = off
PORTAL_SYNC_CRON=            # default 0 7 * * * (daily 07:00, after the social sync)
PORTAL_SYNC_REFRESH_DAYS=    # default 30 (rolling lookback window)
PORTAL_SYNC_HEADLESS=        # default true; set false to watch selectors while building a fetcher
PORTAL_SYNC_STORAGE_DIR=     # default ./.storage/portal-sync (Playwright cookie cache; gitignore this)

# Add new services below, grouped under a comment header, names only.
